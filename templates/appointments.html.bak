{% extends 'base.html' %}

{% block title %}Appointments - Tujali Telehealth{% endblock %}

{% block extra_css %}
<!-- FullCalendar CSS -->
<link href='https://cdn.jsdelivr.net/npm/fullcalendar@5.11.3/main.min.css' rel='stylesheet' />
<link href='https://cdn.jsdelivr.net/npm/bootstrap-icons@1.8.1/font/bootstrap-icons.css' rel='stylesheet'>
<link href='https://cdn.jsdelivr.net/npm/sweetalert2@11/dist/sweetalert2.min.css' rel='stylesheet'>
<style>
    :root {
        --primary: #4e73df;
        --success: #1cc88a;
        --info: #36b9cc;
        --warning: #f6c23e;
        --danger: #e74a3b;
        --light: #f8f9fc;
        --dark: #5a5c69;
        --border-radius: 0.35rem;
        --box-shadow: 0 0.15rem 1.75rem 0 rgba(58, 59, 69, 0.15);
    }
    
    .calendar-container {
        margin: 2rem 0;
    }
    
    #calendar {
        background: #fff;
        border-radius: var(--border-radius);
        box-shadow: var(--box-shadow);
        padding: 1.5rem;
        min-height: 600px;
    }
    
    .fc-header-toolbar {
        margin: 0 0 1.5rem 0 !important;
        padding: 1rem;
        background: #fff;
        border-radius: var(--border-radius);
        box-shadow: 0 0.15rem 0.5rem rgba(0, 0, 0, 0.05);
    }
    
    .fc-button {
        background: #fff;
        border: 1px solid #e3e6f0;
        color: #6e707e;
        padding: 0.4rem 1rem;
        font-size: 0.85rem;
        border-radius: 0.35rem;
    }
    
    .fc-button:hover {
        background: #f8f9fc;
    }
    
    .fc-button-primary:not(:disabled).fc-button-active,
    .fc-button-primary:not(:disabled):active {
        background: var(--primary);
        border-color: var(--primary);
        color: white;
    }
    
    /* Event status colors */
    .event-pending { background-color: var(--warning); border-color: var(--warning); }
    .event-confirmed { background-color: var(--success); border-color: var(--success); }
    .event-completed { background-color: var(--info); border-color: var(--info); }
    .event-cancelled { background-color: var(--danger); border-color: var(--danger); }
    
    .fc-event {
        color: white;
        border: none;
        padding: 2px 5px;
        margin-bottom: 2px;
    }
    
    .fc-event .fc-event-main {
        padding: 2px 5px;
    }
    
    .loading-overlay {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: rgba(255, 255, 255, 0.8);
        z-index: 9999;
        justify-content: center;
        align-items: center;
    }
    
    .loading-spinner {
        width: 3rem;
        height: 3rem;
    }
    
    .calendar-container {
        margin: 2rem 0;
    }
    
    #calendar {
        background: #fff;
        border-radius: var(--border-radius);
        box-shadow: var(--box-shadow);
        padding: 1.5rem;
        min-height: 600px;
    }
    
    .fc-header-toolbar {
        margin: 0 0 1.5rem 0 !important;
        padding: 1rem;
        background: #fff;
        border-radius: var(--border-radius);
        box-shadow: 0 0.15rem 0.5rem rgba(0, 0, 0, 0.05);
    }
    
    .fc-button {
        background: #fff;
        border: 1px solid #e3e6f0;
        color: #6e707e;
        padding: 0.4rem 1rem;
        font-size: 0.85rem;
        border-radius: 0.35rem;
    }
    
    .fc-button:hover {
        background: #f8f9fc;
    }
    
    .fc-button-primary:not(:disabled).fc-button-active,
    .fc-button-primary:not(:disabled):active {
        background: var(--primary);
        border-color: var(--primary);
    }
    
    /* Event status colors */
    .event-pending { background-color: var(--warning); border-color: var(--warning); }
    .event-confirmed { background-color: var(--success); border-color: var(--success); }
    .event-completed { background-color: var(--info); border-color: var(--info); }
    .event-cancelled { background-color: var(--danger); border-color: var(--danger); }
    
    .calendar-container {
        margin: 1.5rem 0;
        transition: all 0.3s ease;
    }
    
    #calendar {
        background: #fff;
        border-radius: var(--border-radius);
        box-shadow: var(--box-shadow);
        padding: 1.5rem;
        min-height: 600px;
        transition: all 0.3s ease;
    }
    
    .fc-header-toolbar {
        margin: 0 0 1.5rem 0 !important;
        padding: 0.75rem 1rem;
        background: #fff;
        border-radius: var(--border-radius);
        box-shadow: 0 0.15rem 0.5rem rgba(0, 0, 0, 0.05);
        flex-wrap: wrap;
        gap: 0.5rem;
        align-items: center;
    }
    
    .fc-toolbar-title {
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--dark);
        margin: 0;
        padding: 0.5rem 0;
    }
    
    .fc-button {
        background: #fff;
        border: 1px solid #e3e6f0;
        color: #6e707e;
        padding: 0.4rem 1rem;
        font-size: 0.85rem;
        font-weight: 500;
        border-radius: 0.35rem;
        transition: all 0.2s ease;
        box-shadow: none;
        text-transform: capitalize;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }
    
    .fc-button:hover {
        background: #f8f9fc;
        border-color: #d1d3e2;
        color: #5a5c69;
    }
    
    .fc-button:active, 
    .fc-button:focus {
        box-shadow: 0 0 0 0.2rem rgba(78, 115, 223, 0.25);
        outline: none;
    }
    
    .fc-button-primary:not(:disabled).fc-button-active {
        background: var(--primary);
        border-color: var(--primary);
        color: white;
    }
    
    .fc-button .fc-icon {
        font-size: 1.1em;
        vertical-align: middle;
    }
    
    .fc-button:hover {
        background: #0b5ed7;
    }
    
    .fc-button-primary:not(:disabled).fc-button-active, 
    .fc-button-primary:not(:disabled):active {
        background: #0a58ca;
    }
    
    /* Calendar Events */
    .fc-event {
        border: none;
        border-radius: 0.25rem;
        padding: 0.35rem 0.5rem;
        font-size: 0.8rem;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.2s ease;
        margin: 0.1rem 0.2rem;
        border-left: 3px solid rgba(0,0,0,0.1);
        box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.05);
    }
    
    .fc-event:hover {
        transform: translateY(-2px);
        box-shadow: 0 0.35rem 0.75rem rgba(0, 0, 0, 0.1);
        z-index: 1000 !important;
    }
    
    .fc-event .fc-event-main {
        padding: 0.15rem 0.25rem;
        display: flex;
        align-items: center;
        gap: 0.4rem;
    }
    
    .fc-event .fc-event-time {
        font-weight: 600;
        opacity: 0.9;
    }
    
    .fc-event .fc-event-title {
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    
    /* Event Status Dots */
    .event-status-dot {
        display: inline-block;
        width: 10px;
        height: 10px;
        border-radius: 50%;
        margin-right: 6px;
        flex-shrink: 0;
    }
    
    /* Day and Time Grid */
    .fc .fc-daygrid-day {
        transition: background-color 0.2s ease;
    }
    
    .fc .fc-daygrid-day:hover {
        background-color: rgba(0, 0, 0, 0.02);
    }
    
    .fc .fc-daygrid-day.fc-day-today {
        background-color: rgba(13, 110, 253, 0.1);
    }
    
    .fc .fc-daygrid-day-top {
        padding: 0.5rem 0.5rem 0 0.5rem;
        flex-direction: row;
        justify-content: flex-start;
    }
    
    .fc .fc-daygrid-day-number {
        font-weight: 600;
        color: var(--dark);
        padding: 0.25rem 0.5rem;
        border-radius: 50%;
        width: 28px;
        height: 28px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    
    .fc .fc-day-today .fc-daygrid-day-number {
        background-color: var(--primary);
        color: white;
    }
    
    .fc .fc-col-header-cell {
        padding: 0.75rem 0.5rem;
        background-color: #f8f9fc;
    }
    
    .fc .fc-col-header-cell-cushion {
        color: var(--dark);
        font-weight: 600;
        text-transform: uppercase;
        font-size: 0.75rem;
        letter-spacing: 0.5px;
    }
    
    /* Event Status Colors */
    .event-pending { 
        background-color: var(--warning); 
        color: #000;
        border-left-color: rgba(0, 0, 0, 0.2);
    }
    
    .event-confirmed { 
        background-color: var(--success); 
        color: #fff;
        border-left-color: rgba(255, 255, 255, 0.3);
    }
    
    .event-completed { 
        background-color: var(--info); 
        color: #fff;
        border-left-color: rgba(255, 255, 255, 0.3);
    }
    
    .event-cancelled { 
        background-color: var(--danger); 
        color: #fff;
        border-left-color: rgba(255, 255, 255, 0.3);
    }
    
    /* Scrollbar Styling */
    ::-webkit-scrollbar {
        width: 8px;
        height: 8px;
    }
    
    ::-webkit-scrollbar-track {
        background: #f1f1f1;
        border-radius: 10px;
    }
    
    ::-webkit-scrollbar-thumb {
        background: #c1c1c1;
        border-radius: 10px;
    }
    
    ::-webkit-scrollbar-thumb:hover {
        background: #a8a8a8;
    }
</style>
{% endblock %}

{% block content %}
<div class="container-fluid">
    <!-- Loading Overlay -->
    <div id="loadingOverlay" class="loading-overlay">
        <div class="spinner-border text-primary loading-spinner" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
    
    <!-- Page Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="h3 mb-0">
            <i class="bi bi-calendar3 me-2"></i>Appointments
        </h1>
        <button id="newAppointmentBtn" class="btn btn-primary">
            <i class="bi bi-plus-circle me-2"></i>New Appointment
        </button>
    </div>
    
    <!-- Calendar Container -->
    <div class="card shadow-sm mb-4">
        <div class="card-body p-0">
            <div id="calendar"></div>
        </div>
    </div>
    </div>
    
    <!-- Calendar Container -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card shadow-sm position-relative">
                <!-- Loading Overlay -->
                <div id="calendar-loading" class="position-absolute w-100 h-100 bg-white d-flex flex-column align-items-center justify-content-center" style="z-index: 10; display: none;">
                    <div class="spinner-border text-primary mb-2" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <p class="text-muted">Loading appointments...</p>
                </div>
                
                <!-- Calendar Header -->
                <div class="card-header bg-white border-bottom d-flex align-items-center py-3">
                    <h5 class="mb-0">
                        <i data-feather="calendar" class="me-2"></i>Appointment Calendar
                    </h5>
                    <div class="ms-auto d-flex align-items-center">
                        <div class="me-3 d-flex align-items-center">
                            <span class="legend-dot bg-warning me-1"></span>
                            <small class="text-muted me-3">Pending</small>
                            <span class="legend-dot bg-success me-1"></span>
                            <small class="text-muted me-3">Confirmed</small>
                            <span class="legend-dot bg-info me-1"></span>
                            <small class="text-muted">Completed</small>
                        </div>
                        <button id="refresh-calendar" class="btn btn-sm btn-outline-secondary" title="Refresh">
                            <i data-feather="refresh-cw" class="feather-sm"></i>
                        </button>
                    </div>
                </div>
                
                <!-- Calendar Container -->
                <div class="card-body p-0">
                    <div id="calendar" class="calendar-container"></div>
                </div>
                
                <!-- Calendar Footer -->
                <div class="card-footer bg-white border-top py-2 d-flex justify-content-between align-items-center">
                    <small class="text-muted">
                        <i data-feather="info" class="feather-sm me-1"></i>
                        Click on an event for details or drag to reschedule
                    </small>
                    <div class="d-flex align-items-center">
                        <div class="form-check form-switch me-3">
                            <input class="form-check-input" type="checkbox" id="compactView" checked>
                            <label class="form-check-label small" for="compactView">Compact View</label>
                        </div>
                        <button class="btn btn-sm btn-primary" id="newAppointmentBtn">
                            <i data-feather="plus" class="feather-sm me-1"></i> New Appointment
                        </button>
                    </div>
                </div>
        </div>
    </div>

<div class="row mb-4">
    <div class="col-md-8">
        <h2 class="mb-0">
            <i data-feather="list" class="me-2"></i> Appointments
        </h2>
    </div>
    <div class="col-md-4 text-end">
        <a href="{{ url_for('create_appointment') }}" class="btn btn-primary">
            <i class="fas fa-plus me-1"></i> New Appointment
        </a>
    </div>
</div>

<!-- Appointment Status Cards -->
<div class="row mb-4">
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-white bg-warning h-100">
            <div class="card-body">
                <h5 class="card-title">Pending</h5>
                <h2 class="display-4">{{ appointments|selectattr('status', 'equalto', 'pending')|list|length }}</h2>
                <p class="card-text">Waiting for confirmation</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-white bg-success h-100">
            <div class="card-body">
                <h5 class="card-title">Confirmed</h5>
                <h2 class="display-4">{{ appointments|selectattr('status', 'equalto', 'confirmed')|list|length }}</h2>
                <p class="card-text">Ready for consultation</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-white bg-info h-100">
            <div class="card-body">
                <h5 class="card-title">Completed</h5>
                <h2 class="display-4">{{ appointments|selectattr('status', 'equalto', 'completed')|list|length }}</h2>
                <p class="card-text">Successfully conducted</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card border-0 shadow-sm text-white bg-danger h-100">
            <div class="card-body">
                <h5 class="card-title">Cancelled</h5>
                <h2 class="display-4">{{ appointments|selectattr('status', 'equalto', 'cancelled')|list|length }}</h2>
                <p class="card-text">Could not be conducted</p>
            </div>
        </div>
    </div>
</div>

<!-- Appointment List -->
<div class="row">
    <div class="col-md-12">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-transparent">
                <div class="d-flex justify-content-between align-items-center">
                    <ul class="nav nav-tabs card-header-tabs" id="appointmentTabs" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link active" id="all-tab" data-bs-toggle="tab" data-bs-target="#all" type="button" role="tab" aria-controls="all" aria-selected="true">All</button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="pending-tab" data-bs-toggle="tab" data-bs-target="#pending" type="button" role="tab" aria-controls="pending" aria-selected="false">Pending</button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="confirmed-tab" data-bs-toggle="tab" data-bs-target="#confirmed" type="button" role="tab" aria-controls="confirmed" aria-selected="false">Confirmed</button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="completed-tab" data-bs-toggle="tab" data-bs-target="#completed" type="button" role="tab" aria-controls="completed" aria-selected="false">Completed</button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link" id="cancelled-tab" data-bs-toggle="tab" data-bs-target="#cancelled" type="button" role="tab" aria-controls="cancelled" aria-selected="false">Cancelled</button>
                        </li>
                    </ul>
                    <div class="input-group" style="max-width: 300px;">
                        <input type="text" class="form-control" placeholder="Search appointments..." id="appointmentSearch">
                        <button class="btn btn-outline-secondary" type="button">
                            <i data-feather="search" style="width: 16px; height: 16px;"></i>
                        </button>
                    </div>
                </div>
            </div>
            <div class="card-body p-0">
                <div class="tab-content" id="appointmentTabsContent">
                    <div class="tab-pane fade show active" id="all" role="tabpanel" aria-labelledby="all-tab">
                        <div class="table-responsive">
                            <table class="table table-hover appointment-table">
                                <thead>
                                    <tr>
                                        <th>ID</th>
                                        <th>Patient ID</th>
                                        <th>Date</th>
                                        <th>Time</th>
                                        <th>Status</th>
                                        <th>Created</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% if appointments %}
                                        {% for appointment in appointments %}
                                        <tr>
                                            <td>{{ appointment.id }}</td>
                                            <td>
                                                <a href="{{ url_for('patient_detail', patient_id=appointment.patient_id) }}">
                                                    {{ appointment.patient_id }}
                                                </a>
                                            </td>
                                            <td>{{ appointment.date }}</td>
                                            <td>{{ appointment.time }}</td>
                                            <td>
                                                <span class="badge {% if appointment.status == 'pending' %}bg-warning{% elif appointment.status == 'confirmed' %}bg-success{% elif appointment.status == 'completed' %}bg-info{% elif appointment.status == 'cancelled' %}bg-danger{% else %}bg-secondary{% endif %}">
                                                    {{ appointment.status|capitalize }}
                                                </span>
                                            </td>
                                            <td>{{ appointment.created_at.strftime('%d %b %Y') }}</td>
                                            <td>
                                                <div class="btn-group" role="group">
                                                    {% if appointment.status == 'pending' %}
                                                    <form action="{{ url_for('update_appointment') }}" method="post" class="d-inline">
                                                        <input type="hidden" name="appointment_id" value="{{ appointment.id }}">
                                                        <input type="hidden" name="status" value="confirmed">
                                                        <button type="submit" class="btn btn-sm btn-success">Confirm</button>
                                                    </form>
                                                    <form action="{{ url_for('update_appointment') }}" method="post" class="d-inline">
                                                        <input type="hidden" name="appointment_id" value="{{ appointment.id }}">
                                                        <input type="hidden" name="status" value="cancelled">
                                                        <button type="submit" class="btn btn-sm btn-danger">Cancel</button>
                                                    </form>
                                                    {% elif appointment.status == 'confirmed' %}
                                                    <form action="{{ url_for('update_appointment') }}" method="post" class="d-inline">
                                                        <input type="hidden" name="appointment_id" value="{{ appointment.id }}">
                                                        <input type="hidden" name="status" value="completed">
                                                        <button type="submit" class="btn btn-sm btn-primary">Complete</button>
                                                    </form>
                                                    <form action="{{ url_for('update_appointment') }}" method="post" class="d-inline">
                                                        <input type="hidden" name="appointment_id" value="{{ appointment.id }}">
                                                        <input type="hidden" name="status" value="cancelled">
                                                        <button type="submit" class="btn btn-sm btn-danger">Cancel</button>
                                                    </form>
                                                    {% endif %}
                                                </div>
                                            </td>
                                        </tr>
                                        {% endfor %}
                                    {% else %}
                                        <tr>
                                            <td colspan="7" class="text-center py-4">
                                                <i data-feather="calendar" class="mb-2 text-muted"></i>
                                                <p class="mb-0 text-muted">No appointments scheduled yet</p>
                                            </td>
                                        </tr>
                                    {% endif %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                    
                    <!-- Pending Tab -->
                    <div class="tab-pane fade" id="pending" role="tabpanel" aria-labelledby="pending-tab">
                        <div class="table-responsive">
                            <table class="table table-hover appointment-table">
                                <thead>
                                    <tr>
                                        <th>ID</th>
                                        <th>Patient ID</th>
                                        <th>Date</th>
                                        <th>Time</th>
                                        <th>Created</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% set pending_appointments = appointments|selectattr('status', 'equalto', 'pending')|list %}
                                    {% if pending_appointments %}
                                        {% for appointment in pending_appointments %}
                                        <tr>
                                            <td>{{ appointment.id }}</td>
                                            <td>
                                                <a href="{{ url_for('patient_detail', patient_id=appointment.patient_id) }}">
                                                    {{ appointment.patient_id }}
                                                </a>
                                            </td>
                                            <td>{{ appointment.date }}</td>
                                            <td>{{ appointment.time }}</td>
                                            <td>{{ appointment.created_at.strftime('%d %b %Y') }}</td>
                                            <td>
                                                <div class="btn-group" role="group">
                                                    <form action="{{ url_for('update_appointment') }}" method="post" class="d-inline">
                                                        <input type="hidden" name="appointment_id" value="{{ appointment.id }}">
                                                        <input type="hidden" name="status" value="confirmed">
                                                        <button type="submit" class="btn btn-sm btn-success">Confirm</button>
                                                    </form>
                                                    <form action="{{ url_for('update_appointment') }}" method="post" class="d-inline">
                                                        <input type="hidden" name="appointment_id" value="{{ appointment.id }}">
                                                        <input type="hidden" name="status" value="cancelled">
                                                        <button type="submit" class="btn btn-sm btn-danger">Cancel</button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                        {% endfor %}
                                    {% else %}
                                        <tr>
                                            <td colspan="6" class="text-center py-4">
                                                <i data-feather="calendar" class="mb-2 text-muted"></i>
                                                <p class="mb-0 text-muted">No pending appointments</p>
                                            </td>
                                        </tr>
                                    {% endif %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                    
                    <!-- Confirmed Tab -->
                    <div class="tab-pane fade" id="confirmed" role="tabpanel" aria-labelledby="confirmed-tab">
                        <div class="table-responsive">
                            <table class="table table-hover appointment-table">
                                <thead>
                                    <tr>
                                        <th>ID</th>
                                        <th>Patient ID</th>
                                        <th>Date</th>
                                        <th>Time</th>
                                        <th>Created</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% set confirmed_appointments = appointments|selectattr('status', 'equalto', 'confirmed')|list %}
                                    {% if confirmed_appointments %}
                                        {% for appointment in confirmed_appointments %}
                                        <tr>
                                            <td>{{ appointment.id }}</td>
                                            <td>
                                                <a href="{{ url_for('patient_detail', patient_id=appointment.patient_id) }}">
                                                    {{ appointment.patient_id }}
                                                </a>
                                            </td>
                                            <td>{{ appointment.date }}</td>
                                            <td>{{ appointment.time }}</td>
                                            <td>{{ appointment.created_at.strftime('%d %b %Y') }}</td>
                                            <td>
                                                <div class="btn-group" role="group">
                                                    <form action="{{ url_for('update_appointment') }}" method="post" class="d-inline">
                                                        <input type="hidden" name="appointment_id" value="{{ appointment.id }}">
                                                        <input type="hidden" name="status" value="completed">
                                                        <button type="submit" class="btn btn-sm btn-primary">Complete</button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                        {% endfor %}
                                    {% else %}
                                        <tr>
                                            <td colspan="6" class="text-center py-4">
                                                <i data-feather="calendar" class="mb-2 text-muted"></i>
                                                <p class="mb-0 text-muted">No confirmed appointments</p>
                                            </td>
                                        </tr>
                                    {% endif %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                    
                    <!-- Other tabs similar structure -->
                    <div class="tab-pane fade" id="completed" role="tabpanel" aria-labelledby="completed-tab">
                        <!-- Similar table for completed appointments -->
                        <div class="table-responsive">
                            <table class="table table-hover appointment-table">
                                <thead>
                                    <tr>
                                        <th>ID</th>
                                        <th>Patient ID</th>
                                        <th>Date</th>
                                        <th>Time</th>
                                        <th>Created</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% set completed_appointments = appointments|selectattr('status', 'equalto', 'completed')|list %}
                                    {% if completed_appointments %}
                                        {% for appointment in completed_appointments %}
                                        <tr>
                                            <td>{{ appointment.id }}</td>
                                            <td>
                                                <a href="{{ url_for('patient_detail', patient_id=appointment.patient_id) }}">
                                                    {{ appointment.patient_id }}
                                                </a>
                                            </td>
                                            <td>{{ appointment.date }}</td>
                                            <td>{{ appointment.time }}</td>
                                            <td>{{ appointment.created_at.strftime('%d %b %Y') }}</td>
                                        </tr>
                                        {% endfor %}
                                    {% else %}
                                        <tr>
                                            <td colspan="5" class="text-center py-4">
                                                <i data-feather="calendar" class="mb-2 text-muted"></i>
                                                <p class="mb-0 text-muted">No completed appointments</p>
                                            </td>
                                        </tr>
                                    {% endif %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                    
                    <div class="tab-pane fade" id="cancelled" role="tabpanel" aria-labelledby="cancelled-tab">
                        <!-- Similar table for cancelled appointments -->
                        <div class="table-responsive">
                            <table class="table table-hover appointment-table">
                                <thead>
                                    <tr>
                                        <th>ID</th>
                                        <th>Patient ID</th>
                                        <th>Date</th>
                                        <th>Time</th>
                                        <th>Created</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% set cancelled_appointments = appointments|selectattr('status', 'equalto', 'cancelled')|list %}
                                    {% if cancelled_appointments %}
                                        {% for appointment in cancelled_appointments %}
                                        <tr>
                                            <td>{{ appointment.id }}</td>
                                            <td>
                                                <a href="{{ url_for('patient_detail', patient_id=appointment.patient_id) }}">
                                                    {{ appointment.patient_id }}
                                                </a>
                                            </td>
                                            <td>{{ appointment.date }}</td>
                                            <td>{{ appointment.time }}</td>
                                            <td>{{ appointment.created_at.strftime('%d %b %Y') }}</td>
                                        </tr>
                                        {% endfor %}
                                    {% else %}
                                        <tr>
                                            <td colspan="5" class="text-center py-4">
                                                <i data-feather="calendar" class="mb-2 text-muted"></i>
                                                <p class="mb-0 text-muted">No cancelled appointments</p>
                                            </td>
                                        </tr>
                                    {% endif %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
</div>

<!-- Status Update Confirmation Modal -->
<div class="modal fade" id="statusUpdateModal" tabindex="-1" aria-labelledby="statusUpdateModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="statusUpdateModalLabel">Confirm Status Update</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <p>Are you sure you want to update this appointment status to <strong><span id="newStatusDisplay"></span></strong>?</p>
                <p class="text-muted small">This action will notify the patient if their appointment status changes.</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="confirmStatusUpdate">Update Status</button>
            </div>
        </div>
    </div>
</div>

<!-- Appointment Details Modal -->
<div class="modal fade" id="appointmentDetailsModal" tabindex="-1" aria-labelledby="appointmentDetailsModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="appointmentDetailsModalLabel">Appointment Details</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body" id="appointmentDetailsBody">
                <!-- Content will be dynamically inserted here -->
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                <button type="button" class="btn btn-primary" id="viewPatientBtn">
                    <i data-feather="user" class="feather-sm me-1"></i> View Patient
                </button>
            </div>
        </div>
    </div>
</div>

{% block extra_js %}
    <!-- Load all required scripts in order -->
    <script src="https://cdn.jsdelivr.net/npm/moment@2.29.1/moment.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@5.11.3/main.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@fullcalendar/interaction@5.11.3/main.global.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/@fullcalendar/moment@5.11.3/main.global.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <link href="https://cdn.jsdelivr.net/npm/fullcalendar@5.11.3/main.min.css" rel="stylesheet" />
    
    <script>
    document.addEventListener('DOMContentLoaded', function() {
        // Initialize the calendar when the DOM is fully loaded
        let calendar;
        const calendarEl = document.getElementById('calendar');
        const loadingOverlay = document.getElementById('loadingOverlay');
        
        // Show loading overlay
        function showLoading(show = true) {
            loadingOverlay.style.display = show ? 'flex' : 'none';
        }
        
        // Show error message using SweetAlert2
        function showError(message) {
            Swal.fire({
                icon: 'error',
                title: 'Error',
                text: message,
                confirmButtonColor: '#4e73df'
            });
        }
        
        // Format date for display
        function formatDate(date) {
            return moment(date).format('YYYY-MM-DD HH:mm');
        }
        
        // Initialize the calendar
        function initCalendar() {
            try {
                calendar = new FullCalendar.Calendar(calendarEl, {
                    initialView: 'dayGridMonth',
                    headerToolbar: {
                        left: 'prev,next today',
                        center: 'title',
                        right: 'dayGridMonth,timeGridWeek,timeGridDay'
                    },
                    themeSystem: 'bootstrap',
                    firstDay: 1, // Monday
                    height: 'auto',
                    nowIndicator: true,
                    selectable: true,
                    selectMirror: true,
                    dayMaxEvents: true,
                    navLinks: true,
                    events: JSON.parse('{{ calendar_events|tojson|safe }}'),
                    eventContent: function(arg) {
                        // Custom event rendering
                        const event = arg.event;
                        const status = event.extendedProps.status || 'pending';
                        const time = event.start ? moment(event.start).format('h:mm A') : '';
                        
                        const eventEl = document.createElement('div');
                        eventEl.className = `fc-event-main ${status}`;
                        
                        const timeEl = document.createElement('div');
                        timeEl.className = 'fc-event-time';
                        timeEl.textContent = time;
                        
                        const titleEl = document.createElement('div');
                        titleEl.className = 'fc-event-title';
                        titleEl.textContent = event.title;
                        
                        eventEl.appendChild(timeEl);
                        eventEl.appendChild(titleEl);
                        
                        return { domNodes: [eventEl] };
                    },
                    eventClick: function(info) {
                        // Handle event click
                        const event = info.event;
                        const patientName = event.extendedProps.patient_name || 'Unknown Patient';
                        const status = event.extendedProps.status || 'pending';
                        const notes = event.extendedProps.notes || 'No notes available';
                        
                        Swal.fire({
                            title: 'Appointment Details',
                            html: `
                                <p><strong>Patient:</strong> ${patientName}</p>
                                <p><strong>Time:</strong> ${formatDate(event.start)}</p>
                                <p><strong>Status:</strong> <span class="badge bg-${getStatusBadgeClass(status)}">${status}</span></p>
                                <p><strong>Notes:</strong> ${notes}</p>
                            `,
                            showCancelButton: true,
                            confirmButtonText: 'Edit',
                            cancelButtonText: 'Close',
                            confirmButtonColor: '#4e73df',
                            showDenyButton: true,
                            denyButtonText: 'Delete',
                            denyButtonColor: '#e74a3b'
                        }).then((result) => {
                            if (result.isConfirmed) {
                                // Handle edit
                                editAppointment(event);
                            } else if (result.isDenied) {
                                // Handle delete
                                deleteAppointment(event);
                            }
                        });
                    },
                    dateClick: function(info) {
                        // Handle date click (create new event)
                        createNewAppointment(info.date);
                    },
                    loading: function(isLoading) {
                        showLoading(isLoading);
                    },
                    eventDidMount: function(info) {
                        // Add status class to events
                        const status = info.event.extendedProps.status || 'pending';
                        info.el.classList.add(`event-${status}`);
                    }
                });
                
                calendar.render();
                
                // Add event listeners
                document.getElementById('newAppointmentBtn').addEventListener('click', function() {
                    createNewAppointment();
                });
                
                console.log('Calendar initialized successfully');
                
            } catch (error) {
                console.error('Error initializing calendar:', error);
                showError('Failed to initialize the calendar. Please refresh the page.');
            }
        }
        
        // Get status badge class
        function getStatusBadgeClass(status) {
            const statusClasses = {
                'pending': 'warning',
                'confirmed': 'success',
                'completed': 'info',
                'cancelled': 'danger'
            };
            return statusClasses[status] || 'secondary';
        }
        
        // Create new appointment
        function createNewAppointment(date = null) {
            // Implementation for creating a new appointment
            console.log('Create new appointment', date);
            // TODO: Implement create appointment modal
        }
        
        // Edit appointment
        function editAppointment(event) {
            // Implementation for editing an appointment
            console.log('Edit appointment', event);
            // TODO: Implement edit appointment functionality
        }
        
        // Delete appointment
        function deleteAppointment(event) {
            // Implementation for deleting an appointment
            console.log('Delete appointment', event);
            // TODO: Implement delete confirmation and API call
        }
        
        // Initialize the calendar
        initCalendar();
        
        // Initialize Bootstrap tooltips and popovers
        const tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
        tooltipTriggerList.forEach(function(tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl);
        });
        
        const popoverTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="popover"]'));
        popoverTriggerList.forEach(function(popoverTriggerEl) {
            return new bootstrap.Popover(popoverTriggerEl);
        });
        
        console.log('Bootstrap components initialized');
        
    });
    </script>
    
    <!-- Hidden element to store calendar events data -->
    <div id="calendar-events" style="display: none;">
        {{ calendar_events|tojson|safe }}
    </div>
    
    <style>
        /* Calendar styles */
        #calendar {
            width: 100%;
            min-height: 600px;
            margin: 0 auto;
        }
        
        .fc-event {
            cursor: pointer;
            border: none;
            border-radius: 4px;
            padding: 2px 5px;
            margin: 1px 0;
            font-size: 0.85em;
        }
        
        .fc-event .fc-event-main {
            padding: 2px 4px;
        }
        
        .fc-event-time {
            font-weight: bold;
            margin-right: 4px;
        }
        
        .fc-event-title {
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        
        /* Status-based event colors */
        .event-pending {
            background-color: #ffc107;
            border-color: #ffc107;
            color: #000;
        }
        
        .event-confirmed {
            background-color: #198754;
            border-color: #198754;
            color: #fff;
        }
        
        .event-completed {
            background-color: #0dcaf0;
            border-color: #0dcaf0;
            color: #000;
        }
        
        .event-cancelled {
            background-color: #dc3545;
            border-color: #dc3545;
            color: #fff;
        }
        
        /* Loading overlay */
        .loading-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(255, 255, 255, 0.8);
            display: flex;
            justify-content: center;
            align-items: center;
            z-index: 9999;
            display: none;
        }
        
        .loading-spinner {
            width: 3rem;
            height: 3rem;
        }
    </style>

    <!-- Hidden element to store calendar events data -->
    <div id="calendar-events" style="display: none;">
        {{ calendar_events|tojson|safe }}
    </div>

    <!-- Initialize Bootstrap tooltips and popovers -->
    <script>
    document.addEventListener('DOMContentLoaded', function() {
        // Initialize tooltips
        const tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
        tooltipTriggerList.forEach(function(tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl);
        });
        
        // Initialize popovers
        const popoverTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="popover"]'));
        popoverTriggerList.forEach(function(popoverTriggerEl) {
            return new bootstrap.Popover(popoverTriggerEl);
        });
    });
    </script>

    <!-- New Appointment Modal -->
    <div class="modal fade" id="newAppointmentModal" tabindex="-1" aria-labelledby="newAppointmentModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="newAppointmentModalLabel">New Appointment</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form id="appointmentForm">
                        <div class="mb-3">
                            <label for="patientName" class="form-label">Patient Name</label>
                            <input type="text" class="form-control" id="patientName" required>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="startTime" class="form-label">Start Time</label>
                                <input type="datetime-local" class="form-control" id="startTime" required>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="endTime" class="form-label">End Time</label>
                                <input type="datetime-local" class="form-control" id="endTime">
                            </div>
                        </div>
                        <div class="mb-3">
                            <label for="appointmentStatus" class="form-label">Status</label>
                            <select class="form-select" id="appointmentStatus">
                                <option value="pending">Pending</option>
                                <option value="confirmed" selected>Confirmed</option>
                                <option value="completed">Completed</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label for="appointmentNotes" class="form-label">Notes</label>
                            <textarea class="form-control" id="appointmentNotes" rows="3" placeholder="Additional notes (optional)"></textarea>
                        </div>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-primary" id="saveAppointmentBtn">Save Appointment</button>
                </div>
            </div>
        </div>
    </div>

    <script>
    // Show new appointment modal
    function showNewAppointmentModal() {
        const modal = new bootstrap.Modal(document.getElementById('newAppointmentModal'));
        const form = document.getElementById('appointmentForm');
        
        // Reset form
        form.reset();
        
        // Set default times
        const now = new Date();
        const defaultStart = new Date(now.getTime() + 60 * 60 * 1000); // 1 hour from now
        defaultStart.setMinutes(0, 0, 0); // Round to nearest hour
        
        const defaultEnd = new Date(defaultStart.getTime() + 30 * 60 * 1000); // 30 minutes later
        
        // Format for datetime-local input
        document.getElementById('startTime').value = formatDateTimeForInput(defaultStart);
        document.getElementById('endTime').value = formatDateTimeForInput(defaultEnd);
        
        // Show the modal
        modal.show();
    }
    
    // Helper function to format date for datetime-local input
    function formatDateTimeForInput(date) {
        const year = date.getFullYear();
        const month = String(date.getMonth() + 1).padStart(2, '0');
        const day = String(date.getDate()).padStart(2, '0');
        const hours = String(date.getHours()).padStart(2, '0');
        const minutes = String(date.getMinutes()).padStart(2, '0');
        
        return `${year}-${month}-${day}T${hours}:${minutes}`;
    }
    
    // Handle form submission
    document.getElementById('saveAppointmentBtn').addEventListener('click', async function() {
        const form = document.getElementById('appointmentForm');
        if (!form.checkValidity()) {
            form.classList.add('was-validated');
            return;
        }
        
        const appointmentData = {
            patientName: document.getElementById('patientName').value,
            start: document.getElementById('startTime').value,
            end: document.getElementById('endTime').value || null,
            status: document.getElementById('appointmentStatus').value,
            notes: document.getElementById('appointmentNotes').value
        };
        
        try {
            // Show loading state
            const saveBtn = document.getElementById('saveAppointmentBtn');
            const originalBtnText = saveBtn.innerHTML;
            saveBtn.disabled = true;
            saveBtn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Saving...';
            
            // In a real app, you would make an API call here
            // For now, we'll simulate a network request
            await new Promise(resolve => setTimeout(resolve, 1000));
            
            // Create the new event
            const newEvent = {
                id: 'event-' + Date.now(),
                title: appointmentData.patientName,
                start: appointmentData.start,
                end: appointmentData.end || new Date(new Date(appointmentData.start).getTime() + 30 * 60000).toISOString(),
                status: appointmentData.status || 'pending',
                extendedProps: {
                    status: appointmentData.status || 'pending',
                    patientName: appointmentData.patientName,
                    notes: appointmentData.notes || '',
                    patient_phone: 'N/A',
                    createdAt: new Date().toISOString(),
                    updatedAt: new Date().toISOString()
                },
                backgroundColor: statusColors[appointmentData.status]?.bg || '#6c757d',
                borderColor: statusColors[appointmentData.status]?.bg || '#6c757d',
                textColor: statusColors[appointmentData.status]?.text || '#fff',
                className: `event-${appointmentData.status || 'pending'}`,
                editable: true
            };
            
            // Add the event to the calendar
            calendar.addEvent(newEvent);
            
            // Close the modal
            const modal = bootstrap.Modal.getInstance(document.getElementById('newAppointmentModal'));
            modal.hide();
            
            // Show success message
            showToast('Appointment created successfully!', 'success');
            
        } catch (error) {
            console.error('Error creating appointment:', error);
            showError('Failed to create appointment. Please try again.');
        } finally {
            // Reset the button state
            const saveBtn = document.getElementById('saveAppointmentBtn');
            saveBtn.disabled = false;
            saveBtn.innerHTML = 'Save Appointment';
        }
    });
    
    // Show the modal
    modal.show();
}

// Show edit appointment modal
function showEditAppointmentModal(event) {
    // TODO: Implement edit appointment functionality
    console.log('Edit appointment:', event);
    showToast('Edit functionality coming soon!', 'info');
}

// Confirm appointment deletion
function confirmDeleteAppointment(event) {
    Swal.fire({
        title: 'Delete Appointment',
        text: 'Are you sure you want to delete this appointment?',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonText: 'Yes, delete it!',
        cancelButtonText: 'No, keep it',
        reverseButtons: true
    }).then((result) => {
        if (result.isConfirmed) {
            // In a real app, you would make an API call to delete the appointment
            event.remove();
            showToast('Appointment deleted!', 'success');
        }
    });
}

// Update event status
function updateEventStatus(eventId, newStatus) {
    // In a real app, you would make an API call to update the status
    const event = calendar.getEventById(eventId);
    if (event) {
        event.setProp('status', newStatus);
        event.setProp('backgroundColor', statusColors[newStatus]?.bg || '#6c757d');
        event.setProp('textColor', statusColors[newStatus]?.text || '#fff');
        showToast('Status updated!', 'success');
    }
}

// Handle event click
function handleEventClick(clickInfo) {
    const event = clickInfo.event;
    const status = event.extendedProps.status;
    const patientName = event.extendedProps.patientName || 'Unknown Patient';
    const notes = event.extendedProps.notes || 'No additional notes';
    const patientPhone = event.extendedProps.patient_phone || 'N/A';
    
    // Format date and time
    const formatDateTime = (date) => {
        if (!date) return 'N/A';
        const d = new Date(date);
        return d.toLocaleString('en-US', {
            weekday: 'short',
            month: 'short',
            day: 'numeric',
            year: 'numeric',
            hour: '2-digit',
            minute: '2-digit'
        });
    };
    
    // Create status options
    const statusOptions = Object.entries({
        'pending': { bg: '#ffc107', text: 'dark' },
        'confirmed': { bg: '#198754', text: 'light' },
        'completed': { bg: '#0dcaf0', text: 'dark' },
        'cancelled': { bg: '#dc3545', text: 'light' }
    }).map(([statusKey, colors]) => {
        const isActive = statusKey === status;
        return `
            <button type="button" 
                    class="dropdown-item d-flex align-items-center ${isActive ? 'active' : ''}" 
                    onclick="updateEventStatus('${event.id}', '${statusKey}')">
                <span class="badge bg-${isActive ? colors.bg.replace('#', '') : 'secondary'} me-2">
                    ${statusKey.charAt(0).toUpperCase() + statusKey.slice(1)}
                </span>
                ${statusKey.charAt(0).toUpperCase() + statusKey.slice(1)}
            </button>`;
    }).join('');
    
    // Create modal content
    const modalContent = `
        <div class="appointment-details">
            <div class="text-center mb-4">
                <div class="badge p-2 mb-3" 
                     style="background-color: ${statusColors[status]?.bg || '#6c757d'}; color: ${statusColors[status]?.text || '#fff'};">
                    ${status.toUpperCase()}
                </div>
                <h4 class="mb-3">${patientName}</h4>
                <div class="text-muted mb-3">
                    <i class="bi bi-telephone me-2"></i>${patientPhone}
                </div>
                <div class="text-muted mb-3">
                    <i class="bi bi-calendar-event me-2"></i>
                    ${formatDateTime(event.start)}
                    ${event.end ? ` - ${formatDateTime(event.end)}` : ''}
                </div>
                ${notes ? `
                <div class="alert alert-light text-start">
                    <i class="bi bi-chat-square-text me-2"></i>
                    ${notes}
                </div>` : ''}
                
                <div class="dropdown d-inline-block mt-2">
                    <button class="btn btn-outline-secondary dropdown-toggle" 
                            type="button" 
                            id="statusDropdown" 
                            data-bs-toggle="dropdown" 
                            aria-expanded="false">
                        <i class="bi bi-pencil-square me-1"></i> Change Status
                    </button>
                    <div class="dropdown-menu dropdown-menu-end" aria-labelledby="statusDropdown">
                        ${statusOptions}
                    </div>
                </div>
            </div>
        </div>`;
    
    // Show the modal
    Swal.fire({
        title: 'Appointment Details',
        html: modalContent,
        showCloseButton: true,
        showCancelButton: true,
        confirmButtonText: '<i class="bi bi-pencil me-1"></i> Edit',
        cancelButtonText: '<i class="bi bi-trash me-1"></i> Delete',
        showDenyButton: true,
        denyButtonText: 'Close',
        customClass: {
            confirmButton: 'btn btn-primary me-2',
            cancelButton: 'btn btn-danger me-2',
            denyButton: 'btn btn-secondary'
        },
        buttonsStyling: false,
        didOpen: () => {
            // Initialize tooltips for any elements that need them
            const tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
            tooltipTriggerList.map(function(tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl);
            });
        }
    }).then((result) => {
        if (result.isConfirmed) {
            // Edit button clicked
            showEditAppointmentModal(event);
        } else if (result.dismiss === Swal.DismissReason.cancel) {
            // Delete button clicked
            confirmDeleteAppointment(event);
        }
    });
}

// Update event status
function updateEventStatus(eventId, newStatus) {
    showLoading(true);
    
    // In a real app, you would make an API call here
    setTimeout(() => {
        try {
            const event = calendar.getEventById(eventId);
            if (event) {
                // Update event properties
                event.setExtendedProp('status', newStatus);
                event.setExtendedProp('updatedAt', new Date().toISOString());
                
                // Update visual appearance
                event.setProp('backgroundColor', statusColors[newStatus]?.bg || '#6c757d');
                event.setProp('borderColor', statusColors[newStatus]?.bg || '#6c757d');
                event.setProp('textColor', statusColors[newStatus]?.text || '#fff');
                
                // Show success message
                showToast('Status updated!', 'success');
            }
        } catch (error) {
            console.error('Error updating status:', error);
            showError('Failed to update status');
        } finally {
            showLoading(false);
            Swal.close();
        }
    }, 500);
}

// Edit an existing appointment
function editAppointment(event) {
    const currentStatus = event.extendedProps.status;
    
    Swal.fire({
        title: 'Edit Appointment',
        html: `
            <div class="mb-3">
                <label class="form-label">Patient Name</label>
                <input id="editPatientName" class="form-control" value="${event.extendedProps.patientName}" required>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Start Time</label>
                    <input type="datetime-local" id="editStartTime" class="form-control" value="${event.start ? formatDateTimeForInput(event.start) : ''}" required>
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">End Time</label>
                    <input type="datetime-local" id="editEndTime" class="form-control" value="${event.end ? formatDateTimeForInput(event.end) : ''}">
                </div>
            </div>
            <div class="mb-3">
                <label class="form-label">Status</label>
                <select id="editStatus" class="form-select">
                    ${Object.entries(statusColors).map(([status, data]) => 
                        `<option value="${status}" ${status === currentStatus ? 'selected' : ''}>
                            ${status.charAt(0).toUpperCase() + status.slice(1)}
                        </option>`
                    ).join('')}
                </select>
            </div>
            <div class="mb-3">
                <label class="form-label">Notes</label>
                <textarea id="editNotes" class="form-control" rows="3">${event.extendedProps.notes || ''}</textarea>
            </div>
        `,
        focusConfirm: false,
        showCancelButton: true,
        confirmButtonText: 'Save Changes',
        cancelButtonText: 'Cancel',
        showLoaderOnConfirm: true,
        preConfirm: () => ({
            patientName: document.getElementById('editPatientName').value,
            start: document.getElementById('editStartTime').value,
            end: document.getElementById('editEndTime').value,
            status: document.getElementById('editStatus').value,
            notes: document.getElementById('editNotes').value
        })
    }).then((result) => {
        if (result.isConfirmed && result.value) {
            updateAppointment(event, result.value);
        }
    });
}

// Update an existing appointment
function updateAppointment(event, updateData) {
    showLoading(true);
    
    // In a real app, you would make an API call here
    setTimeout(() => {
        try {
            // Update the event properties
            event.setProp('title', updateData.patientName);
            event.setStart(updateData.start);
            event.setEnd(updateData.end || moment(updateData.start).add(30, 'minutes').toISOString());
            
            // Update extended props
            event.setExtendedProp('status', updateData.status);
            event.setExtendedProp('patientName', updateData.patientName);
            event.setExtendedProp('notes', updateData.notes);
            event.setExtendedProp('updatedAt', new Date().toISOString());
            
            // Update visual properties
            event.setProp('backgroundColor', statusColors[updateData.status]?.bg || '#6c757d');
            event.setProp('borderColor', statusColors[updateData.status]?.bg || '#6c757d');
            event.setProp('textColor', statusColors[updateData.status]?.text || '#fff');
            
            // Show success message
            showToast('Appointment updated!', 'success');
            
        } catch (error) {
            console.error('Error updating appointment:', error);
            showError('Failed to update appointment');
        } finally {
            showLoading(false);
        }
    }, 800);
}

// Delete an appointment
function deleteAppointment(event) {
    Swal.fire({
        title: 'Are you sure?',
        text: 'This will permanently delete this appointment.',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#dc3545',
        cancelButtonColor: '#6c757d',
        confirmButtonText: 'Yes, delete it!',
        cancelButtonText: 'Cancel',
        reverseButtons: true
    }).then((result) => {
        if (result.isConfirmed) {
            showLoading(true);
            
            // In a real app, you would make an API call here
            setTimeout(() => {
                try {
                    event.remove();
                    showToast('Appointment deleted!', 'success');
                } catch (error) {
                    console.error('Error deleting appointment:', error);
                    showError('Failed to delete appointment');
                } finally {
                    showLoading(false);
                }
            }, 500);
        }
    });
}

// Show loading overlay
function showLoading(show) {
    const loadingOverlay = document.getElementById('loading-overlay');
    if (loadingOverlay) {
        loadingOverlay.style.display = show ? 'flex' : 'none';
    }
}

// Show success toast
function showToast(message, type = 'success') {
    const Toast = Swal.mixin({
        toast: true,
        position: 'top-end',
        showConfirmButton: false,
        timer: 3000,
        timerProgressBar: true,
        didOpen: (toast) => {
            toast.addEventListener('mouseenter', Swal.stopTimer);
            toast.addEventListener('mouseleave', Swal.resumeTimer);
        }
    });
    
    Toast.fire({
        icon: type,
        title: message
    });
}

// Show error message
function showError(message) {
    Swal.fire({
        icon: 'error',
        title: 'Error',
        text: message,
        confirmButtonText: 'OK'
    });
}

// Refresh the calendar
function refreshCalendar() {
    showLoading(true);
    // In a real app, you would fetch fresh data from the server here
    setTimeout(() => {
        try {
            calendar.refetchEvents();
            showToast('Calendar refreshed', 'success');
        } catch (error) {
            console.error('Error refreshing calendar:', error);
            showError('Failed to refresh calendar');
        } finally {
            showLoading(false);
        }
    }, 500);
}

// Toggle compact view
function toggleCompactView() {
    const calendarEl = document.getElementById('calendar');
    if (calendarEl) {
        calendarEl.classList.toggle('compact-view');
        calendar.updateSize();
        
        // Save preference to localStorage
        const isCompact = calendarEl.classList.contains('compact-view');
        localStorage.setItem('calendarCompactView', isCompact);
        
        // Update button text
        const toggleBtn = document.getElementById('compactView');
        if (toggleBtn) {
            toggleBtn.checked = isCompact;
        }
    }
}

// Set up event listeners
function setupEventListeners() {
    // Refresh button
    const refreshBtn = document.getElementById('refresh-calendar');
    if (refreshBtn) {
        refreshBtn.addEventListener('click', refreshCalendar);
    }
    
    // New Appointment button
    const newAppointmentBtn = document.getElementById('newAppointmentBtn');
    if (newAppointmentBtn) {
        newAppointmentBtn.addEventListener('click', showNewAppointmentModal);
    }
    
    // Compact view toggle
    const compactViewToggle = document.getElementById('compactView');
    if (compactViewToggle) {
        compactViewToggle.addEventListener('change', toggleCompactView);
        
        // Load saved preference
        const isCompact = localStorage.getItem('calendarCompactView') === 'true';
        if (isCompact) {
            document.getElementById('calendar').classList.add('compact-view');
            compactViewToggle.checked = true;
        }
    }
    
    // Keyboard shortcuts
    document.addEventListener('keydown', (e) => {
        // Refresh with Ctrl+R
        if (e.ctrlKey && e.key === 'r') {
            e.preventDefault();
            refreshCalendar();
        }
        // Clear selection with Escape
        if (e.key === 'Escape') {
            calendar.unselect();
        }
    });
}

// Initialize the calendar with the given events (alias for initializeCalendar for backward compatibility)
function initCalendar(events = []) {
    return initializeCalendar();
}

// Update appointment time when dragged or resized
function updateAppointmentTime(updatedEvent, oldEvent) {
    showLoading(true);
    
    // In a real app, you would make an API call here
    setTimeout(() => {
        try {
            // Get the event from the calendar by ID
            const event = calendar.getEventById(updatedEvent.id);
            if (event) {
                // Update the event's extended properties
                event.setExtendedProp('updatedAt', new Date().toISOString());
                
                // Show success message
                showToast('Appointment updated!', 'success');
            }
        } catch (error) {
            console.error('Error updating appointment time:', error);
            showError('Failed to update appointment time');
            
            // Revert the event to its previous state
            if (oldEvent) {
                updatedEvent.setStart(oldEvent.start);
                updatedEvent.setEnd(oldEvent.end);
                updatedEvent.setAllDay(oldEvent.allDay);
            }
        } finally {
            showLoading(false);
        }
    }, 500);
}

</script>

<!-- Hidden element for calendar events -->
<div id="calendar-events" style="display: none;">
    {{ calendar_events|tojson|safe }}
</div>

<style>
    .status-badge {
        padding: 0.25rem 0.5rem;
        border-radius: 0.25rem;
        font-size: 0.75rem;
        font-weight: 500;
        text-transform: capitalize;
        display: inline-block;
    }
    .status-pending { background-color: #ffc107; color: #000; }
    .status-confirmed { background-color: #198754; color: #fff; }
    .status-completed { background-color: #0dcaf0; color: #000; }
    .status-cancelled { background-color: #dc3545; color: #fff; }
    .status-btn { min-width: 100px; text-align: left; }
    .status-option i { width: 20px; text-align: center; }
    .appointment-row { transition: background-color 0.3s ease; }
    .appointment-row:hover { background-color: rgba(0, 0, 0, 0.02); }
    
    /* Calendar event styles */
    .fc-event {
        border: 1px solid rgba(0, 0, 0, 0.1);
        border-radius: 0.25rem;
        padding: 0.15rem 0.3rem;
        font-size: 0.85rem;
        cursor: pointer;
    }
    
    .fc-event .fc-event-main {
        padding: 0.1rem 0.25rem;
    }
    
    .fc-event-time {
        font-weight: 600;
        margin-right: 0.25rem;
    }
    
    .fc-event-title {
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    
    /* Responsive adjustments */
    @media (max-width: 768px) {
        .fc-toolbar-title {
            font-size: 1.25rem;
        }
        
        .fc .fc-toolbar.fc-header-toolbar {
            flex-direction: column;
            gap: 0.5rem;
        }
        
        .fc-toolbar-chunk {
            margin-bottom: 0.5rem;
        }
    }
</style>

{% endblock %}
